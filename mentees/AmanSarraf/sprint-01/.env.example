# Copy to .env and pick ONE backend below (Aura or local Docker).
# Never commit .env.

# --- Option A — Neo4j AuraDB Free (cloud) ---
# NEO4J_URI=neo4j+s://YOUR_INSTANCE.databases.neo4j.io
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=your-aura-password
# NEO4J_DATABASE=neo4j
# AURA_INSTANCEID=your-short-instance-id
# AURA_INSTANCENAME=TA Sprint 01-O*NET

# --- Option B — Local Neo4j via Docker (docker compose up -d) ---
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=onet-sprint-local
NEO4J_DATABASE=neo4j